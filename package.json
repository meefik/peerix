{
  "name": "peerix",
  "version": "0.5.0",
  "description": "A library for creating peer-to-peer WebRTC applications with custom signaling drivers and add-ons.",
  "author": "Peerix <info@peerix.dev>",
  "license": "Apache-2.0",
  "homepage": "https://peerix.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/peerix-dev/peerix.git"
  },
  "keywords": [
    "webrtc",
    "p2p",
    "peer-to-peer",
    "conferencing",
    "signaling",
    "real-time"
  ],
  "type": "module",
  "main": "dist/peerix.esm.js",
  "types": "dist/index.d.ts",
  "module": "dist/peerix.esm.js",
  "unpkg": "dist/peerix.umd.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "test:unit": "node --import tsx --test 'src/**/*.test.ts'",
    "test:e2e": "playwright test",
    "test": "npm run test:unit && npm run test:e2e",
    "docs": "typedoc && cat docs/globals.md > docs/llms.txt && cat docs/README.md docs/**/*.md | grep -v '^\\[\\*\\*' > docs/llms-full.txt"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.0"
  }
}
