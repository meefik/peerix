{
  "name": "peerix",
  "version": "0.1.0",
  "description": "A library for creating peer-to-peer WebRTC applications with custom signaling drivers and add-ons.",
  "author": "Peerix <info@peerix.dev>",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/peerix-dev/peerix.git"
  },
  "keywords": [
    "webrtc",
    "p2p",
    "peer-to-peer",
    "conferencing",
    "signaling",
    "real-time"
  ],
  "type": "module",
  "main": "dist/peerix.esm.js",
  "types": "dist/index.d.ts",
  "module": "dist/peerix.esm.js",
  "unpkg": "dist/peerix.umd.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && tsc --emitDeclarationOnly",
    "test": "playwright test",
    "docs": "typedoc && cat docs/globals.md > docs/llms.txt && cat docs/README.md docs/**/*.md > docs/llms-full.txt"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "vite": "^8.0.10"
  }
}